OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
PORT=3080
# Places: local JSON (default: AI_agent/places_data.json, else ../nikola/places_data.json)
# PLACES_DATA_PATH=../nikola/places_data.json
# Cap rows returned per fetch_places_catalog (full file still used for map enrichment)
# PLACES_TOOL_MAX_ITEMS=120
# Reviews included per place in tool payload (text truncated by PLACES_TOOL_REVIEW_MAX_CHARS)
# PLACES_TOOL_REVIEWS_PER_PLACE=6
# PLACES_TOOL_REVIEW_MAX_CHARS=600
# Max events (with lat/lng) sent per fetch_events_catalog (full events.json used for enrichment)
# EVENTS_TOOL_MAX_ITEMS=250
